# Copy to .env for local development. NEVER commit real secrets.

# Postgres/Supabase connection string used by supabase/seed.sh and psql.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/igb

# API service
PORT=8080

# Set automatically by Railway on GitHub-connected services; only needed locally
# if you want /version to report a specific SHA.
# RAILWAY_GIT_COMMIT_SHA=

# Supabase project (public values only; service-role keys stay in the vault).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- API auth boundary (server-only secrets; NEVER commit real values) ---
# The API verifies Supabase JWTs with HS256 against the project's JWT secret.
# Set this as a Railway service variable (sourced from the vault), not here.
# Without it, all authenticated routes fail closed (401).
# SUPABASE_JWT_SECRET=
# Service-role key is server-only and never sent to clients or committed.
# SUPABASE_SERVICE_ROLE_KEY=
