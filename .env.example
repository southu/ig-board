# Copy to .env for local development. NEVER commit real secrets.

# Postgres/Supabase connection string used by supabase/seed.sh and psql.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/igb

# API service
PORT=8080
# HOST=0.0.0.0
# Optional: override the static web export dir the API serves (auto-detected when
# unset; the server logs the resolved root at boot). See docs/env.md.
# WEB_ROOT=

# Set automatically by Railway on GitHub-connected services; only needed locally
# if you want /version to report a specific SHA.
# RAILWAY_GIT_COMMIT_SHA=

# Supabase project. See docs/env.md for the full name reference.
# Project URL (used by both the API for admin ops and the web client).
# SUPABASE_URL=
# Anon (public) key — CLIENT-SIDE ONLY. Safe to expose; RLS is the guard.
# SUPABASE_ANON_KEY=
# Next.js public mirrors (web build reads these prefixed names).
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- API auth boundary (server-only secrets; NEVER commit real values) ---
# The API verifies Supabase JWTs with HS256 against the project's JWT secret.
# Set this as a Railway service variable (sourced from the vault), not here.
# Without it, all authenticated routes fail closed (401).
# SUPABASE_JWT_SECRET=
# Service-role key is server-only (bypasses RLS) and never sent to clients or committed.
# SUPABASE_SERVICE_ROLE_KEY=
# Anthropic provider key for independent analysis (POST /api/independent-analysis).
# Server-only — never commit a real value; bind on Railway from the vault.
# ANTHROPIC_API_KEY=

# --- Operator live smoke (npm run test:smoke) — never commit real values ---
# LIVE_URL=https://ig-board-production.up.railway.app
# SMOKE_FOUNDER_EMAIL=
# SMOKE_FOUNDER_PASSWORD=
# SMOKE_BOARD_EMAIL=
# SMOKE_BOARD_PASSWORD=
# Optional token inject (skips magic-link OTP):
# SMOKE_FOUNDER_JWT=
# SMOKE_BOARD_JWT=
